# Neon PostgreSQL connection string
# Get this from https://console.neon.tech after creating a project
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# AI API Key (fallback if not configured in Settings UI)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Drive Service Account (for Drive browser integration)
# Set this to the full JSON content of your Google service account key file
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...",...}
